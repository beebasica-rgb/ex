-- HOOK DE Instance.new
-- Captura CADA instancia GUI mientras el hub las crea.
-- Si buildGUI() crashea a mitad, tendremos todo lo que se creó hasta ese punto.
-- ─────────────────────────────────────────────────────────────────────────────

local hookedInstances = {}   -- tabla de todas las instancias GUI hookeadas
local hookActive      = false

local function setupInstanceHook()
    -- Solo hookear si hookfunction está disponible
    local _hf = rawget(getfenv and getfenv(0) or _G, "hookfunction")
                or (getgenv and getgenv().hookfunction)
    if not _hf then
        print("[BKS GE] hookfunction no disponible — usando solo snapshot")
        return false
    end

    local _nc = rawget(getfenv and getfenv(0) or _G, "newcclosure")
                or (getgenv and getgenv().newcclosure)
    if not _nc then
        print("[BKS GE] newcclosure no disponible — usando solo snapshot")
        return false
    end

    local realInstanceNew = Instance.new
    local _holder = { fn = nil }

    _holder.fn = _hf(Instance.new, _nc(function(cn, parent)
        local inst = _holder.fn(cn, parent)
        if SERIALIZE[cn] then
            -- Registrar con un pequeño delay para que las propiedades se apliquen
            _ins(hookedInstances, inst)
        end
        return inst
    end))

    hookActive = true
    print("[BKS GE] Instance.new hookeado — capturando instancias GUI...")
    return true
end

-- ─────────────────────────────────────────────────────────────────────────────
-- EXTRACCIÓN PRINCIPAL
-- ─────────────────────────────────────────────────────────────────────────────

local extractionDone = false

local function doExtract(source)
    if extractionDone then
        notify("BKS GE", "Ya se extrajo. Reinicia para volver a capturar.", 5)
        return
    end
    extractionDone = true

    notify("BKS GE", "Buscando GUI... (" .. source .. ")", 4)

    -- Estrategia 1: snapshot del árbol actual (mejor calidad)
    local roots = findRoots()

    if #roots == 0 then
        -- Estrategia 2: usar instancias hookeadas si el hub crasheó antes de llegar a PlayerGui
        if hookActive and #hookedInstances > 0 then
            notify("BKS GE",
                _fmt("Snapshot vacío. Usando %d instancias hookeadas...", #hookedInstances), 5)
            -- Filtrar instancias que aún existen y son ScreenGui o hijos de una
            local sgs = {}
            for _, inst in _ipairs(hookedInstances) do
                local ok, cn = _pcall(function() return inst.ClassName end)
                if ok and cn == "ScreenGui" then
                    _ins(sgs, inst)
                end
            end
            if #sgs > 0 then
                roots = sgs
            end
        end
    end

    if #roots == 0 then
        notify("BKS GE",
            "⚠ No se encontró GUI. El hub no llegó a crear la ScreenGui.\n" ..
            "Prueba: carga el hub primero, luego presiona F8.", 10)
        extractionDone = false  -- permitir reintento
        return
    end

    notify("BKS GE",
        _fmt("Encontradas %d ScreenGui. Serializando...", #roots), 5)

    -- Generar código
    local code      = buildCode(roots)
    local bytes     = #code
    local lineCount = select(2, code:gsub("\n","")) + 1

    print(_fmt("[BKS GE] Output: %d líneas, %.1f KB", lineCount, bytes/1024))

    -- Intentar guardar
    local saved = false
    local url   = nil

    -- Hastebin / Rentry (mejor para archivos grandes)
    if bytes > 100000 then
        notify("BKS GE", _fmt("%.0f KB — subiendo a hastebin...", bytes/1024), 5)
        url = hasteSave(code)
        if not url then url = rentrySave(code) end
        if url then
            saved = true
            clipSave(url)   -- URL en clipboard
            notify("BKS GE",
                _fmt("✓ Subido! (%.0f KB)\n%s", bytes/1024, url), 15)
            print("[BKS GE] URL: " .. url)
        end
    end

    -- Clipboard (para archivos pequeños o si hastebin falló)
    if not saved then
        local clipped = clipSave(code)
        if clipped then
            saved = true
            notify("BKS GE", _fmt("✓ En clipboard! (%.0f KB)", bytes/1024), 8)
        end
        -- También intentar hastebin como backup
        if CFG.SAVE_HASTEBIN and not url then
            url = hasteSave(code) or rentrySave(code)
            if url then
                print("[BKS GE] Backup URL: " .. url)
                notify("BKS GE", "Backup en hastebin: " .. url, 10)
            end
        end
    end

    -- Último recurso: print chunks
    if not saved then
        notify("BKS GE", "Clipboard y hastebin fallaron. Imprimiendo en consola...", 5)
        chunkPrint(code)
    elseif CFG.PRINT_CHUNKS then
        -- Imprimir de todas formas como backup adicional
        chunkPrint(code)
    end

    notify("BKS GE", "✓ Extracción completa.", 5)
end

