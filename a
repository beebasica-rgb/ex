-- Busca TODAS las ScreenGui con prefijo _zk (para captura manual F8)
local function findAllZk()
    local roots = {}
    local seen  = {}
    local function tryAdd(container)
        local ok, children = _pcall(function() return container:GetChildren() end)
        if not ok then return end
        for _, c in _ipairs(children) do
            local cn=safeClass(c); local nm=safeName(c)
            if cn=="ScreenGui" and nm:sub(1,3)=="_zk" and not seen[nm] then
                seen[nm]=true; _ins(roots,c)
            end
        end
    end
    tryAdd(PlayerGui)
    tryAdd(CoreGuiSvc)
    return roots
end

