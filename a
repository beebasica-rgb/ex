end

-- ─────────────────────────────────────────────────────────────────────────────
-- ESPERAR ESTABILIZACIÓN DE LA GUI
-- Cuenta descendientes cada STABLE_INTERVAL segundos.
-- Cuando el count no cambia en STABLE_CHECKS checks → GUI lista.
-- ─────────────────────────────────────────────────────────────────────────────
local function waitStable(inst)
    local prev    = -1
    local sameRun = 0
    local t0      = tick()

    print(_fmt("[BKS GE] Esperando estabilización de %s...", safeName(inst)))

    while (tick()-t0) < CFG.STABLE_TIMEOUT do
        task.wait(CFG.STABLE_INTERVAL)
        local count = safeDescCount(inst)
        if count == prev then
            sameRun = sameRun + 1
            print(_fmt("[BKS GE]   stable %d/%d (desc=%d)",
                sameRun, CFG.STABLE_CHECKS, count))
            if sameRun >= CFG.STABLE_CHECKS then
                print(_fmt("[BKS GE] GUI estable con %d descendientes.", count))
                return true
            end
        else
            if prev ~= -1 then
                print(_fmt("[BKS GE]   creciendo: %d → %d", prev, count))
            end
            sameRun = 0
            prev    = count
        end
    end

    print("[BKS GE] Timeout de estabilización — capturando de todas formas.")
    return false
end

