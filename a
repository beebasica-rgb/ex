--[[
  BKS HUB — Delta Report
  Ejecutar DESPUÉS de cargar el hub (aunque crashee).
  Muestra qué funciones llamó Luraph y si alguna falló.
--]]

local log = (type(getgenv)=="function" and getgenv().__BKS_NIL_LOG__)
         or _G.__BKS_NIL_LOG__
         or {}

local out
if #log == 0 then
    out = "[BKS REPORT] nilLog vacío — el hub no llamó funciones interceptadas,\n"
       .. "o el catcher no se ejecutó antes del hub."
else
    out = "=== BKS Nil Catcher Report ===\n" .. table.concat(log, "\n")
end

print(out)
pcall(setclipboard, out)
print("[REPORT] Output en clipboard.")
