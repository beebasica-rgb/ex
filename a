local function trySave(code)
    local bytes = #code

    -- 1) Hastebin
    if CFG.SAVE_HASTEBIN then
        local reqFn = (type(request)=="function" and request)
                   or (type(syn)=="table" and type(syn.request)=="function" and syn.request)
                   or nil
        if reqFn then
            notify("BKS v3", _fmt("%.0f KB — subiendo a hastebin...", bytes/1024), 5)
            local ok, res = _pcall(reqFn, {
                Url    = "https://hastebin.com/documents",
                Method = "POST",
                Body   = code,
                Headers= { ["Content-Type"] = "text/plain" },
            })
            if ok and res and res.Body then
                local ok2, data = _pcall(function() return HttpService:JSONDecode(res.Body) end)
                if ok2 and data and data.key then
                    local url = "https://hastebin.com/" .. data.key
                    print("[BKS v3] ✓ Hastebin: " .. url)
                    if type(setclipboard)=="function" then _pcall(setclipboard, url) end
                    notify("BKS v3", _fmt("✓ Hastebin OK (%.0f KB)\n%s", bytes/1024, url), 15)
                    return
                end
            end
            -- Hastebin falló → intentar con rentry
            local ok2, res2 = _pcall(reqFn, {
                Url    = "https://rentry.co/api",
                Method = "POST",
                Body   = "text=" .. HttpService:UrlEncode(code),
                Headers= {
                    ["Content-Type"] = "application/x-www-form-urlencoded",
                    ["Referer"]      = "https://rentry.co",
                },
            })
            if ok2 and res2 and res2.Body then
                local ok3, d2 = _pcall(function() return HttpService:JSONDecode(res2.Body) end)
                if ok3 and d2 and d2.url then
                    local url = d2.url .. "/raw"
                    print("[BKS v3] ✓ Rentry: " .. url)
                    if type(setclipboard)=="function" then _pcall(setclipboard, url) end
                    notify("BKS v3", _fmt("✓ Rentry OK (%.0f KB)\n%s", bytes/1024, url), 15)
                    return
                end
            end
        end
    end

    -- 2) Clipboard (código completo)
    if CFG.SAVE_CLIPBOARD and type(setclipboard) == "function" then
        -- Clipboard tiene límite en algunos executors; dividir si es muy grande
        local CLIP_MAX = 200000
        if bytes <= CLIP_MAX then
            local ok = _pcall(setclipboard, code)
            if ok then
                notify("BKS v3", _fmt("✓ Clipboard (%.0f KB)", bytes/1024), 8)
                return
            end
        else
            -- Dividir en partes numeradas
            local part = 1
            for i = 1, bytes, CLIP_MAX do
                local chunk = code:sub(i, i + CLIP_MAX - 1)
                local ok = _pcall(setclipboard, chunk)
                if ok then
                    notify("BKS v3", _fmt("Clipboard parte %d (%.0f KB)", part, #chunk/1024), 3)
                end
                part = part + 1
                task.wait(0.5)
            end
            return
        end
    end

    -- 3) Último recurso: print en consola
    if CFG.PRINT_CHUNKS then
        local CHUNK = 2500
        local total = bytes
        print(_fmt("[BKS v3] Imprimiendo %d chunks...", math.ceil(total/CHUNK)))
        for i = 1, total, CHUNK do
            print(code:sub(i, i + CHUNK - 1))
            task.wait(0.05)
        end
        print("[BKS v3] ── FIN ──")
    end
end

-- ─────────────────────────────────────────────────────────────────────────────
-- EXTRACCIÓN PRINCIPAL
-- ─────────────────────────────────────────────────────────────────────────────
local function doExtract(mainGui)
    local roots = { mainGui }

    if CFG.CAPTURE_ALL_ZK then
        -- Intentar capturar overlay y botón si existen
        local function tryFind(container, name)
            local ok, c = _pcall(function() return container:FindFirstChild(name) end)
            return (ok and c) or nil
        end
        local ov = tryFind(PlayerGui, CFG.SGUI_OVERLAY) or tryFind(CoreGui, CFG.SGUI_OVERLAY)
        local ob = tryFind(PlayerGui, CFG.SGUI_OPENBTN) or tryFind(CoreGui, CFG.SGUI_OPENBTN)
        if ov then _ins(roots, ov) end
        if ob then _ins(roots, ob) end
    end

    -- Contar descendants para informar
    local totalDesc = 0
    _pcall(function()
        totalDesc = #mainGui:GetDescendants()
    end)

    notify("BKS v3", _fmt("✓ GUI Lista — %d descendants — Capturando...", totalDesc), 5)
    print(_fmt("[BKS v3] Serializando %d raíces, %d descendants...", #roots, totalDesc))

    local code = generateCode(roots)
    local lines = select(2, code:gsub("\n", "")) + 1
    print(_fmt("[BKS v3] Output: %d líneas, %.1f KB", lines, #code/1024))

    trySave(code)
end

-- ─────────────────────────────────────────────────────────────────────────────
-- DETECTOR DE ESTABILIDAD
-- ─────────────────────────────────────────────────────────────────────────────
--[[
  Estrategia:
  1. Encuentra la ScreenGui principal (_zk768057)
  2. Suscribe DescendantAdded (y opcionalmente DescendantRemoving)
     para registrar el "último tiempo de cambio" (lastChange)
  3. En un loop de POLL_RATE segundos comprueba:
       - Hay al menos MIN_DESCENDANTS hijos
       - Han pasado STABILITY_WINDOW segundos desde el último cambio
  4. Cuando se cumple → llama doExtract()
--]]
local function monitorAndCapture(mainGui)
    local lastChange  = _tick()
    local connections = {}

    -- Cada vez que se añade un descendant: actualizar timestamp
    local function onDescAdded(desc)
        lastChange = _tick()
    end

    local ok1, conn1 = _pcall(function()
        return mainGui.DescendantAdded:Connect(onDescAdded)
    end)
    if ok1 and conn1 then _ins(connections, conn1) end

    -- También monitorear DescendantRemoving por si hay ajustes post-build
    local ok2, conn2 = _pcall(function()
        return mainGui.DescendantRemoving:Connect(function() lastChange = _tick() end)
    end)
    if ok2 and conn2 then _ins(connections, conn2) end

    local t0 = _tick()
    local lastLogCount = -1

    notify("BKS v3", "Monitoreando construcción de GUI... (espera estabilidad)", 5)

    -- Loop de monitoreo
    while true do
        task.wait(CFG.POLL_RATE)

        -- Timeout global
        if (_tick() - t0) >= CFG.TIMEOUT then
            notify("BKS v3", "⚠ Timeout — capturando lo que haya...", 5)
            break
        end

        local descCount = 0
        local valid, err = _pcall(function()
            descCount = #mainGui:GetDescendants()
        end)
        if not valid then
            notify("BKS v3", "⚠ GUI destruida: " .. tostring(err), 5)
            -- Desconectar y salir
            for _, c in ipairs(connections) do _pcall(function() c:Disconnect() end) end
            return
        end

        -- Log periódico (cada 10 cambios de conteo)
        if descCount ~= lastLogCount and descCount % 10 == 0 then
            print(_fmt("[BKS v3] ... %d descendants (último cambio hace %.1fs)",
                descCount, _tick() - lastChange))
            lastLogCount = descCount
        end

        -- ¿Suficientes descendants Y estabilidad?
        local timeSinceChange = _tick() - lastChange
        if descCount >= CFG.MIN_DESCENDANTS and timeSinceChange >= CFG.STABILITY_WINDOW then
            print(_fmt("[BKS v3] ✓ Estable: %d descendants, %.1fs sin cambios",
                descCount, timeSinceChange))
            break
        end
    end

    -- Desconectar eventos
    for _, c in ipairs(connections) do _pcall(function() c:Disconnect() end) end

    -- Capturar
    doExtract(mainGui)
end

-- ─────────────────────────────────────────────────────────────────────────────
-- BÚSQUEDA DE LA GUI PRINCIPAL
-- ─────────────────────────────────────────────────────────────────────────────
local function findMainGui()
    -- Buscar por nombre exacto
    local function tryFind(container, name)
        local ok, c = _pcall(function() return container:FindFirstChild(name) end)
        return (ok and c) or nil
    end

    local sg = tryFind(PlayerGui, CFG.SGUI_MAIN) or tryFind(CoreGui, CFG.SGUI_MAIN)
    if sg then return sg end

    -- Fallback: cualquier ScreenGui que empiece por "_zk"
    for _, child in ipairs(PlayerGui:GetChildren()) do
        local cn, nm = "", ""
        _pcall(function() cn = child.ClassName end)
        _pcall(function() nm = child.Name end)
        if cn == "ScreenGui" and nm:sub(1,3) == "_zk" and nm ~= CFG.SGUI_OVERLAY and nm ~= CFG.SGUI_OPENBTN then
            return child
        end
    end
    return nil
end

-- ─────────────────────────────────────────────────────────────────────────────
-- ENTRY POINT
-- ─────────────────────────────────────────────────────────────────────────────
task.spawn(function()
    if not CFG.WAIT_FOR_HUB then
        -- Captura inmediata
        local gui = findMainGui()
        if gui then
            doExtract(gui)
        else
            notify("BKS v3", "⚠ GUI no encontrada. Pon WAIT_FOR_HUB=true", 8)
        end
        return
    end

    -- Modo espera: buscar la GUI en loop, luego monitorear
    notify("BKS v3", "Esperando hub... (timeout: " .. CFG.TIMEOUT .. "s)", 6)

    local t0    = _tick()
    local found = false

    while (_tick() - t0) < CFG.TIMEOUT do
        local gui = findMainGui()
        if gui then
            found = true
            print("[BKS v3] GUI detectada: " .. tostring(gui.Name))
            -- Pasar al monitor de estabilidad
            monitorAndCapture(gui)
            break
        end
        task.wait(0.5)
    end

    if not found then
        notify("BKS v3", "⚠ Timeout — hub no apareció en " .. CFG.TIMEOUT .. "s", 10)
    end
end)

print("[BKS GUI Extractor v3] Inicializado. STABILITY_WINDOW = " .. CFG.STABILITY_WINDOW .. "s")
