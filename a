-- ── 2. Intercepción: envolver funciones con logging ANTES de cargar el hub ───
-- Luraph LPH en su línea 1 normalmente hace UNA de estas cosas:
--   a) getfenv(1) o getfenv(0)
--   b) newcclosure(fn)
--   c) debug.getinfo(fn,"Su")
--   d) Llama a algún global con nombre extraño
--
-- Si ninguna de esas es nil, entonces lo nil es algo DENTRO del hub mismo
-- (una función del juego, un servicio, etc.)

local nilLog = {}
local function wrapLog(name, fn)
    if type(fn) ~= "function" then return fn end
    return newcclosure and newcclosure(function(...)
        local results = table.pack(pcall(fn, ...))
        if not results[1] then
            nilLog[#nilLog+1] = "[CALL ERROR] " .. name .. " → " .. tostring(results[2])
        end
        return table.unpack(results, 2)
    end) or fn
end

-- Envolver funciones clave del entorno global para detectar crashes
local _genv = (type(getgenv)=="function" and getgenv()) or _G
local _orig = {}

local TO_WRAP = {
    "getfenv","setfenv","newcclosure","hookfunction","clonefunction",
    "getupvalues","getprotos","is_closure","isclosure","iscclosure",
    "checkcaller","setreadonly","loadstring",
}

for _, name in ipairs(TO_WRAP) do
    _orig[name] = _genv[name]
    local orig = _genv[name]
    if type(orig)=="function" then
        pcall(function()
            _genv[name] = function(...)
                nilLog[#nilLog+1] = "[PRE] called: " .. name
                local r = table.pack(pcall(orig,...))
                if not r[1] then
                    nilLog[#nilLog+1] = "[ERR] " .. name .. " → " .. tostring(r[2])
                end
                return table.unpack(r, 2)
            end
        end)
    end
end

-- Envolver debug.getinfo
if type(debug)=="table" and type(debug.getinfo)=="function" then
    local orig_gi = debug.getinfo
    pcall(function()
        debug.getinfo = function(...)
            nilLog[#nilLog+1] = "[PRE] called: debug.getinfo"
            local r = table.pack(pcall(orig_gi,...))
            if not r[1] then
                nilLog[#nilLog+1] = "[ERR] debug.getinfo → " .. tostring(r[2])
            end
            return table.unpack(r, 2)
        end
    end)
end

