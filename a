-- KEYBIND MANUAL (F8 = capturar ahora)
-- ─────────────────────────────────────────────────────────────────────────────

UIS.InputBegan:Connect(function(inp, gpe)
    if gpe then return end
    if inp.UserInputType == Enum.UserInputType.Keyboard then
        if inp.KeyCode == CFG.MANUAL_KEY then
            task.spawn(doExtract, "tecla manual F8")
        end
    end
end)

notify("BKS GE", "Listo. F8 = capturar ahora.", 6)
print("[BKS GE] Keybind F8 activo. Esperando hub...")

-- ─────────────────────────────────────────────────────────────────────────────
-- HOOK Instance.new (antes de cargar el hub)
-- ─────────────────────────────────────────────────────────────────────────────

setupInstanceHook()

-- ─────────────────────────────────────────────────────────────────────────────
-- MODO AUTO: esperar GUI o capturar inmediato
-- ─────────────────────────────────────────────────────────────────────────────

if not CFG.WAIT_FOR_HUB then
    -- Captura inmediata
    task.spawn(function()
        task.wait(0.5)
        doExtract("inmediato")
    end)
else
    -- Modo espera automática
    task.spawn(function()
        local t0    = tick()
        local found = false

        while (tick()-t0) < CFG.TIMEOUT do
            -- Buscar cualquier _zk* ScreenGui
            local sg = nil
            _pcall(function()
                for _, nm in _ipairs(CFG.SGUI_NAMES) do
                    sg = PlayerGui:FindFirstChild(nm)
                    if sg then break end
                end
            end)
            if not sg then
                _pcall(function()
                    for _, c in _ipairs(PlayerGui:GetChildren()) do
                        if safeClassName(c) == "ScreenGui"
                        and safeName(c):sub(1,3) == "_zk" then
                            sg = c; break
                        end
                    end
                end)
            end
            -- También buscar en CoreGui
            if not sg then
                _pcall(function()
                    for _, nm in _ipairs(CFG.SGUI_NAMES) do
                        sg = CoreGuiSvc:FindFirstChild(nm)
                        if sg then break end
                    end
                end)
            end

            if sg then
                found = true
                notify("BKS GE",
                    "GUI detectada. Esperando " .. CFG.WAIT_EXTRA .. "s...", 4)
                task.wait(CFG.WAIT_EXTRA)
                doExtract("auto-detect")
                break
            end

            task.wait(0.5)
        end

        if not found then
            notify("BKS GE",
                _fmt("Timeout (%ds). Hub no encontrado. Presiona F8 para intentar ahora.", CFG.TIMEOUT),
                10)
        end
    end)
end
