local function valEq(a, b)
    if a == b then return true end
    local ta = _typeof(a)
    if ta ~= _typeof(b) then return false end
    if ta == "Color3" then
        return _floor(a.R*255+.5)==_floor(b.R*255+.5)
           and _floor(a.G*255+.5)==_floor(b.G*255+.5)
           and _floor(a.B*255+.5)==_floor(b.B*255+.5)
    elseif ta == "UDim2" then
        return rnd(a.X.Scale,5)==rnd(b.X.Scale,5) and _floor(a.X.Offset+.5)==_floor(b.X.Offset+.5)
           and rnd(a.Y.Scale,5)==rnd(b.Y.Scale,5) and _floor(a.Y.Offset+.5)==_floor(b.Y.Offset+.5)
    elseif ta == "UDim" then
        return rnd(a.Scale,5)==rnd(b.Scale,5) and _floor(a.Offset+.5)==_floor(b.Offset+.5)
    elseif ta == "Vector2" then
        return rnd(a.X,5)==rnd(b.X,5) and rnd(a.Y,5)==rnd(b.Y,5)
    elseif ta == "EnumItem" then
        return _tostr(a)==_tostr(b)
    end
    local ok1,s1 = _pcall(_tostr,a)
    local ok2,s2 = _pcall(_tostr,b)
    return ok1 and ok2 and s1==s2
end

local function propsFor(cn)
    local props, seen = {}, {}
    local function add(lst)
        for _, p in _ipairs(lst) do
            if not seen[p] then seen[p]=true; _ins(props,p) end
        end
    end
    if IS_GUI_OBJECT[cn] then add(GUI_BASE) end
    if cn == "ScreenGui"  then add({"Name"}) end
    add(CLASS_PROPS[cn] or {})
    if cn == "TextButton" then add(CLASS_PROPS["TextLabel"] or {}) end
    return props
end

-- ─────────────────────────────────────────────────────────────────────────────
-- SERIALIZACIÓN DE INSTANCIAS
-- ─────────────────────────────────────────────────────────────────────────────

local function makeVar(nm, cn, counters)
    local base = nm:gsub("[^%w]","_")
    if base=="" or base:match("^%d") then base=cn.."_"..base end
    if base=="" then base=cn end
    counters[base] = (counters[base] or 0) + 1
    return base .. "_" .. counters[base]
end

local function serInst(inst, parentVar, depth, lines, counters)
    if CFG.MAX_DEPTH > 0 and depth > CFG.MAX_DEPTH then return lines, nil end

    local cn = safeClassName(inst)
    if cn == "" or not SERIALIZE[cn] then return lines, nil end

    local nm     = safeName(inst)
    local var    = makeVar(nm, cn, counters)
    local ind    = _rep("    ", depth)

    -- Omitir interior de tabs si está configurado
    if CFG.SKIP_TABS and nm:find("^TabFrame_") then
        _ins(lines, _fmt('%s-- [OMITIDO] TabFrame "%s"', ind, nm))
        _ins(lines, "")
        return lines, nil
    end

    _ins(lines, _fmt('%s-- [%s] %q', ind, cn, nm))
    _ins(lines, _fmt('%slocal %s = Instance.new("%s")', ind, var, cn))

    -- Propiedades
    local props = propsFor(cn)
    for _, prop in _ipairs(props) do
        local ok, val = safeProp(inst, prop)
        if ok and val ~= nil then
            local forced  = CFG.FORCE_PROPS[prop]
            local def     = DEFAULTS[prop]
            if forced or (def == nil) or (not valEq(val, def)) then
                -- Omitir Size/Position UDim2 cero si no es forzado
                if not forced and (prop=="Position" or prop=="Size")
                    and _typeof(val)=="UDim2"
                    and val.X.Scale==0 and val.X.Offset==0
                    and val.Y.Scale==0 and val.Y.Offset==0 then
                    -- skip
                else
                    local sv = serVal(val)
                    if sv and sv ~= "nil" then
                        _ins(lines, _fmt('%s%s.%s = %s', ind, var, prop, sv))
                    end
                end
            end
        end
    end

    if parentVar then
        _ins(lines, _fmt('%s%s.Parent = %s', ind, var, parentVar))
    end
    _ins(lines, "")

    -- Hijos
    local children = {}
    _pcall(function() children = inst:GetChildren() end)
    for _, child in _ipairs(children) do
        serInst(child, var, depth+1, lines, counters)
    end

    return lines, var
end

