-- ─────────────────────────────────────────────────────────────────────────────
local function clipSave(text)
    if not CFG.SAVE_CLIPBOARD then return false end
    local ok=_pcall(setclipboard,text); if ok then return true end
    ok=_pcall(function() Clipboard:SetText(text) end); return ok
end

local function pasteSave(text, service, url, body, headers)
    if not CFG.SAVE_HASTEBIN then return nil end
    local ok,res=_pcall(function()
        return request({Url=url,Method="POST",Body=body,Headers=headers})
    end)
    if not ok or not res or not res.Body then return nil end
    local ok2,data=_pcall(function() return HttpSvc:JSONDecode(res.Body) end)
    if ok2 and data then
        if data.key  then return "https://hastebin.com/"..data.key end
        if data.url  then return data.url.."/raw" end
    end
    return nil
end

local function hasteSave(text)
    return pasteSave(text,"hastebin","https://hastebin.com/documents",text,{["Content-Type"]="text/plain"})
end
local function rentrySave(text)
    return pasteSave(text,"rentry","https://rentry.co/api",
        "text="..HttpSvc:UrlEncode(text),
        {["Content-Type"]="application/x-www-form-urlencoded",["Referer"]="https://rentry.co"})
end

local function chunkPrint(text)
    if not CFG.PRINT_CHUNKS then return end
    local CHUNK=3500
    for i=1,#text,CHUNK do print(text:sub(i,i+CHUNK-1)); task.wait(0.05) end
    print("[BKS GE] ── FIN ──")
end

