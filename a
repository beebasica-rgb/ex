-- ─────────────────────────────────────────────────────────────────────────────
-- COMPARACIÓN DE VALORES (para omitir defaults)
-- ─────────────────────────────────────────────────────────────────────────────

local function valEq(a, b)
    if a == b then return true end
    local ta = _typeof(a)
    local tb = _typeof(b)
    if ta ~= tb then return false end
    if ta == "Color3" then
        return _floor(a.R*255+.5) == _floor(b.R*255+.5)
           and _floor(a.G*255+.5) == _floor(b.G*255+.5)
           and _floor(a.B*255+.5) == _floor(b.B*255+.5)
    elseif ta == "UDim2" then
        return rnd(a.X.Scale,5) == rnd(b.X.Scale,5)
           and _floor(a.X.Offset+.5) == _floor(b.X.Offset+.5)
           and rnd(a.Y.Scale,5) == rnd(b.Y.Scale,5)
           and _floor(a.Y.Offset+.5) == _floor(b.Y.Offset+.5)
    elseif ta == "UDim" then
        return rnd(a.Scale,5) == rnd(b.Scale,5)
           and _floor(a.Offset+.5) == _floor(b.Offset+.5)
    elseif ta == "Vector2" then
        return rnd(a.X,5) == rnd(b.X,5) and rnd(a.Y,5) == rnd(b.Y,5)
    elseif ta == "EnumItem" then
        return _tostr(a) == _tostr(b)
    end
    -- ColorSequence, NumberSequence → raro tener default; comparar por string
    local ok1, s1 = _pcall(_tostr, a)
    local ok2, s2 = _pcall(_tostr, b)
    return ok1 and ok2 and s1 == s2
end

-- ─────────────────────────────────────────────────────────────────────────────
-- CONSTRUCTOR DE LISTA DE PROPS PARA UNA CLASE
-- ─────────────────────────────────────────────────────────────────────────────

local function propsForClass(cn)
    local props = {}
    local seen  = {}
    local function add(list)
        for _, p in ipairs(list) do
            if not seen[p] then seen[p] = true; _ins(props, p) end
        end
    end
    -- GuiObject base para clases visuales
    if IS_GUI_OBJECT[cn] then add(GUI_OBJECT_PROPS) end
    -- ScreenGui también usa algunas GuiObject props (Size/Position no aplican)
    if cn == "ScreenGui" then
        add({ "Name" })
    end
    -- Props específicos de clase
    add(CLASS_PROPS[cn] or {})
    -- TextButton también hereda texto de TextLabel
    if IS_TEXT_BUTTON[cn] then
        for _, p in ipairs(CLASS_PROPS["TextLabel"] or {}) do
            if not seen[p] then seen[p] = true; _ins(props, p) end
        end
    end
    return props
end

-- ─────────────────────────────────────────────────────────────────────────────
-- SERIALIZER PRINCIPAL
-- ─────────────────────────────────────────────────────────────────────────────

-- Genera un nombre de variable Lua válido y único
local function makeVarName(instName, cn, counters)
    local base = instName:gsub("[^%w]", "_")
    if base == "" or base:match("^%d") then base = cn .. "_" .. base end
    if base == "" then base = cn end
    counters[base] = (counters[base] or 0) + 1
    return base .. "_" .. counters[base]
end

-- Serializa un Instance recursivamente
-- Retorna: lista de líneas, varName del root
local function serInst(inst, parentVar, depth, lines, counters, rootCn)
    depth    = depth or 0
    lines    = lines or {}
    counters = counters or {}

    if CFG.MAX_DEPTH > 0 and depth > CFG.MAX_DEPTH then return lines, nil end

    local cn = ""
    if not _pcall(function() cn = inst.ClassName end) then return lines, nil end
    if not SERIALIZE_CLASS[cn] then return lines, nil end

    -- Nombre del instance
    local instName = ""
    _pcall(function() instName = inst.Name end)

    local varName = makeVarName(instName, cn, counters)
    local ind     = _rep("    ", depth)

    -- ── Creación ──────────────────────────────────────────────────────────
    _ins(lines, _fmt('%s-- [%s] "%s"', ind, cn, instName))
    _ins(lines, _fmt('%slocal %s = Instance.new("%s")', ind, varName, cn))

    -- ── Propiedades ───────────────────────────────────────────────────────
    local props = propsForClass(cn)
    for _, prop in ipairs(props) do
        local val, ok = nil, false
        _pcall(function() val = inst[prop]; ok = true end)
        if ok and val ~= nil then
            local forced  = FORCE_PROPS_SET[prop]
            local default = DEFAULTS[prop]
            -- Omitir si es default y no es forzada
            if not forced and default ~= nil and valEq(val, default) then
                -- skip
            else
                -- Evitar serializar Position=(0,0,0,0) y Size=(0,0,0,0) para contenedores
                -- excepto si es ScreenGui
                if cn ~= "ScreenGui"
                    and (prop == "Position" or prop == "Size")
                    and _typeof(val) == "UDim2"
                    and val.X.Scale == 0 and val.X.Offset == 0
                    and val.Y.Scale == 0 and val.Y.Offset == 0
                    and not forced then
                    -- skip cero por defecto (en ScreenGui no tiene sentido)
                else
                    local sv = serValue(val)
                    if sv and sv ~= "nil" then
                        _ins(lines, _fmt('%s%s.%s = %s', ind, varName, prop, sv))
                    end
                end
            end
        end
    end

    -- ── Parent ────────────────────────────────────────────────────────────
    if parentVar then
        _ins(lines, _fmt('%s%s.Parent = %s', ind, varName, parentVar))
    end
    _ins(lines, "")

    -- ── Hijos ─────────────────────────────────────────────────────────────
    local children = {}
    _pcall(function() children = inst:GetChildren() end)

    for _, child in ipairs(children) do
        -- Si SKIP_TABS_CONTENT, omitir frames de contenido de tabs (ScrollingFrame con TabFrame_ prefix)
        if CFG.SKIP_TABS_CONTENT then
            local cname = ""
            _pcall(function() cname = child.Name end)
            if cname:find("^TabFrame_") then
                _ins(lines, _fmt('%s-- [OMITTED] TabFrame "%s" (SKIP_TABS_CONTENT=true)', ind .. "    ", cname))
                _ins(lines, "")
                goto continue_child
            end
        end

        serInst(child, varName, depth + 1, lines, counters, rootCn)

        ::continue_child::
    end

    return lines, varName
end

