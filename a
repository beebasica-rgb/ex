-- GENERACIÓN DEL CÓDIGO FINAL
-- ─────────────────────────────────────────────────────────────────────────────
local function generateCode(roots)
    local lines = {}
    _ins(lines, "--[[")
    _ins(lines, "  BKS HUB — GUI Original Extraída por BKS_GUI_EXTRACTOR_v3")
    _ins(lines, "  Capturada con detección de estabilidad (sin corte prematuro).")
    _ins(lines, "  Para usar: ejecutar en un executor de Roblox.")
    _ins(lines, "--]]")
    _ins(lines, "")
    _ins(lines, 'local Players           = game:GetService("Players")')
    _ins(lines, 'local UserInputService  = game:GetService("UserInputService")')
    _ins(lines, 'local TweenService      = game:GetService("TweenService")')
    _ins(lines, 'local RunService        = game:GetService("RunService")')
    _ins(lines, 'local LocalPlayer       = Players.LocalPlayer')
    _ins(lines, 'local PlayerGui         = LocalPlayer:WaitForChild("PlayerGui")')
    _ins(lines, "")
    _ins(lines, "-- Limpiar instancias anteriores del hub")
    _ins(lines, 'for _, nm in ipairs({"' .. CFG.SGUI_MAIN .. '", "' .. CFG.SGUI_OVERLAY .. '", "' .. CFG.SGUI_OPENBTN .. '"}) do')
    _ins(lines, '    local old = PlayerGui:FindFirstChild(nm)')
    _ins(lines, '    if old then old:Destroy() end')
    _ins(lines, 'end')
    _ins(lines, "")
    _ins(lines, "-- ══════════════════════════════════════════")
    _ins(lines, "-- GUI ORIGINAL")
    _ins(lines, "-- ══════════════════════════════════════════")
    _ins(lines, "")

    local counters = {}
    local firstVar = nil
    for _, root in ipairs(roots) do
        local rootLines, rootVar = serInst(root, "PlayerGui", 0, {}, counters)
        if not firstVar then firstVar = rootVar end
        for _, l in ipairs(rootLines) do _ins(lines, l) end
    end

    _ins(lines, "")
    _ins(lines, "-- ══════════════════════════════════════════")
    _ins(lines, "-- KEYBIND TOGGLE (U = mostrar/ocultar)")
    _ins(lines, "-- ══════════════════════════════════════════")
    if firstVar then
        _ins(lines, "local _sg = " .. firstVar)
        _ins(lines, "UserInputService.InputBegan:Connect(function(inp, gpe)")
        _ins(lines, "    if gpe then return end")
        _ins(lines, "    if inp.KeyCode == Enum.KeyCode.U then")
        _ins(lines, "        _sg.Enabled = not _sg.Enabled")
        _ins(lines, "    end")
        _ins(lines, "end)")
    end
    _ins(lines, "")
    _ins(lines, 'print("[BKS GUI v3] Cargada correctamente.")')
    return _cat(lines, "\n")
end

