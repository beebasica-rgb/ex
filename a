-- ─────────────────────────────────────────────────────────────────────────────
-- typeof() con fallback robusto
-- ─────────────────────────────────────────────────────────────────────────────
local _typeof
do
    local ok, tf = _pcall(function() return typeof end)
    if ok and _type(tf) == "function" then
        _typeof = tf
    else
        _typeof = function(v)
            local t = _type(v)
            if t ~= "userdata" then return t end
            -- Detectar tipos Roblox por propiedades únicas
            if _pcall(function() local _=v.R+v.G+v.B end) then return "Color3" end
            if _pcall(function() local _=v.X.Scale+v.Y.Scale end) then return "UDim2" end
            if _pcall(function() local _=v.Scale+v.Offset end) then return "UDim" end
            do
                local ok2, kp = _pcall(function() return v.Keypoints end)
                if ok2 and kp and #kp > 0 then
                    if _pcall(function() local _=kp[1].Value.R end) then return "ColorSequence" end
                    return "NumberSequence"
                end
            end
            if _pcall(function() local _=v.EnumType end) then return "EnumItem" end
            if _pcall(function() local _=v.X+v.Y end) then return "Vector2" end
            local ok3, cn = _pcall(function() return v.ClassName end)
            return ok3 and cn or "userdata"
        end
    end
end

-- ─────────────────────────────────────────────────────────────────────────────
-- UTILIDADES
-- ─────────────────────────────────────────────────────────────────────────────
local function safeProp(inst, prop)
    local ok, v = _pcall(function() return inst[prop] end)
    return ok, v
end
local function safeClass(inst)
    local ok, v = _pcall(function() return inst.ClassName end)
    return ok and v or ""
end
local function safeName(inst)
    local ok, v = _pcall(function() return inst.Name end)
    return ok and v or ""
end
local function safeChildren(inst)
    local ok, v = _pcall(function() return inst:GetChildren() end)
    return ok and v or {}
end
local function safeDescCount(inst)
    local ok, v = _pcall(function() return #inst:GetDescendants() end)
    return ok and v or 0
end

-- ─────────────────────────────────────────────────────────────────────────────
-- SERIALIZADORES
-- ─────────────────────────────────────────────────────────────────────────────
local function rnd(n, d) local f=10^(d or 4); return _floor(n*f+.5)/f end
local function serNum(n)
    if n==_floor(n) and _abs(n)<1e7 then return _tostr(_floor(n)) end
    return (_fmt("%.6f",n):gsub("%.?0+$",""))
end
local function serStr(s)
    return '"'.._tostr(s):gsub("\\","\\\\"):gsub('"','\\"'):gsub("\n","\\n"):gsub("\r","\\r")..'"'
end
local function serC3(c)
    return _fmt("Color3.fromRGB(%d,%d,%d)",_floor(c.R*255+.5),_floor(c.G*255+.5),_floor(c.B*255+.5))
end
local function serUDim2(u)
    return _fmt("UDim2.new(%s,%d,%s,%d)",
        _tostr(rnd(u.X.Scale,5)),_floor(u.X.Offset+.5),
        _tostr(rnd(u.Y.Scale,5)),_floor(u.Y.Offset+.5))
end
local function serUDim(u)
    return _fmt("UDim.new(%s,%d)",_tostr(rnd(u.Scale,5)),_floor(u.Offset+.5))
end
local function serV2(v) return _fmt("Vector2.new(%s,%s)",serNum(v.X),serNum(v.Y)) end
local function serColorSeq(cs)
    local p={}
    for _,kp in _ipairs(cs.Keypoints) do
        _ins(p,_fmt("    ColorSequenceKeypoint.new(%s,%s)",serNum(kp.Time),serC3(kp.Value)))
    end
    return "ColorSequence.new({\n".._cat(p,",\n").."\n})"
end
local function serNumSeq(ns)
    local p={}
    for _,kp in _ipairs(ns.Keypoints) do
        _ins(p,_fmt("    NumberSequenceKeypoint.new(%s,%s,%s)",serNum(kp.Time),serNum(kp.Value),serNum(kp.Envelope)))
    end
    return "NumberSequence.new({\n".._cat(p,",\n").."\n})"
end
local function serRect(r)
    return _fmt("Rect.new(%s,%s,%s,%s)",serNum(r.Min.X),serNum(r.Min.Y),serNum(r.Max.X),serNum(r.Max.Y))
end
local function serVal(v)
    local t=_typeof(v)
    if t=="nil" then return "nil"
    elseif t=="boolean" then return _tostr(v)
    elseif t=="number"  then return serNum(v)
    elseif t=="string"  then return serStr(v)
    elseif t=="Color3"  then return serC3(v)
    elseif t=="UDim2"   then return serUDim2(v)
    elseif t=="UDim"    then return serUDim(v)
    elseif t=="Vector2" then return serV2(v)
    elseif t=="ColorSequence"  then return serColorSeq(v)
    elseif t=="NumberSequence" then return serNumSeq(v)
    elseif t=="Rect"    then return serRect(v)
    elseif t=="EnumItem" then
        local ok,s=_pcall(_tostr,v); return ok and s or "nil"
    else
        local ok,s=_pcall(_tostr,v)
        if ok and s and s~="" and s~="nil" then return serStr(s) end
        return "nil"
    end
end

