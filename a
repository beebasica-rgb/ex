-- GENERACIÓN DEL ARCHIVO FINAL
-- ─────────────────────────────────────────────────────────────────────────────

local function generateCode(guiRoots)
    local lines = {}

    _ins(lines, "--[[")
    _ins(lines, "  BKS HUB — GUI Original Extraída por BKS_GUI_EXTRACTOR_v1")
    _ins(lines, "  Fecha: " .. _tostr(os.date and os.date("%Y-%m-%d %H:%M:%S") or tick()))
    _ins(lines, "  Propiedades extraídas del árbol de instancias REAL en tiempo de ejecución.")
    _ins(lines, "  Para usar: pegar en un executor de Roblox y ejecutar.")
    _ins(lines, "--]]")
    _ins(lines, "")
    _ins(lines, 'local Players           = game:GetService("Players")')
    _ins(lines, 'local UserInputService  = game:GetService("UserInputService")')
    _ins(lines, 'local TweenService      = game:GetService("TweenService")')
    _ins(lines, 'local RunService        = game:GetService("RunService")')
    _ins(lines, 'local LocalPlayer       = Players.LocalPlayer')
    _ins(lines, 'local PlayerGui         = LocalPlayer:WaitForChild("PlayerGui")')
    _ins(lines, "")
    _ins(lines, "-- Limpiar GUI anterior si existe")
    _ins(lines, 'for _, n in ipairs({"' .. CFG.SGUI_MAIN .. '", "' ..
        CFG.SGUI_OVERLAY .. '", "' .. CFG.SGUI_OPENBTN .. '"}) do')
    _ins(lines, '    local old = PlayerGui:FindFirstChild(n)')
    _ins(lines, '    if old then old:Destroy() end')
    _ins(lines, 'end')
    _ins(lines, "")
    _ins(lines, "-- ════════════════════════════════════════════════════")
    _ins(lines, "-- GUI ORIGINAL")
    _ins(lines, "-- ════════════════════════════════════════════════════")
    _ins(lines, "")

    local counters  = {}
    local firstVar  = nil
    for _, root in ipairs(guiRoots) do
        local rootLines, rootVar = serInst(root, "PlayerGui", 0, {}, counters)
        if not firstVar then firstVar = rootVar end
        for _, l in ipairs(rootLines) do _ins(lines, l) end
    end

    -- Footer: keybind toggle
    _ins(lines, "")
    _ins(lines, "-- ════════════════════════════════════════════════════")
    _ins(lines, "-- KEYBIND TOGGLE (U por defecto)")
    _ins(lines, "-- ════════════════════════════════════════════════════")
    if firstVar then
        _ins(lines, "local _hub_sg = " .. firstVar)
        _ins(lines, "UserInputService.InputBegan:Connect(function(inp, gpe)")
        _ins(lines, "    if gpe then return end")
        _ins(lines, "    if inp.UserInputType == Enum.UserInputType.Keyboard then")
        _ins(lines, "        if inp.KeyCode == Enum.KeyCode.U then")
        _ins(lines, "            _hub_sg.Enabled = not _hub_sg.Enabled")
        _ins(lines, "        end")
        _ins(lines, "    end")
        _ins(lines, "end)")
    end
    _ins(lines, "")
    _ins(lines, 'print("[BKS GUI] Cargada correctamente.")')

    return _cat(lines, "\n")
end

