-- ─────────────────────────────────────────────────────────────────────────────
-- GUARDAR Y REPORTAR
-- ─────────────────────────────────────────────────────────────────────────────
local function saveAndReport(code)
    local bytes=#code
    local lines=select(2,code:gsub("\n",""))+1
    print(_fmt("[BKS GE] Output: %d líneas, %.1f KB",lines,bytes/1024))

    local saved=false; local url=nil

    if bytes>80000 then
        notify("BKS GE",_fmt("%.0f KB — subiendo...",bytes/1024),5)
        url=hasteSave(code) or rentrySave(code)
        if url then saved=true; clipSave(url); notify("BKS GE","✓ URL: "..url,15); print("[BKS GE] URL: "..url) end
    end

    if not saved then
        local ok=clipSave(code)
        if ok then saved=true; notify("BKS GE",_fmt("✓ En clipboard (%.0f KB).",bytes/1024),8) end
        -- también subir aunque haya clipboard (backup)
        if CFG.SAVE_HASTEBIN and not url then
            url=hasteSave(code) or rentrySave(code)
            if url then print("[BKS GE] Backup URL: "..url); notify("BKS GE","Backup: "..url,10) end
        end
    end

    if not saved then
        notify("BKS GE","Clipboard falló. Imprimiendo chunks...",5)
        chunkPrint(code)
    else
        chunkPrint(code) -- siempre imprimir como backup adicional
    end
end

-- ─────────────────────────────────────────────────────────────────────────────
-- EXTRACCIÓN DESDE UN CONJUNTO DE RAÍCES
-- ─────────────────────────────────────────────────────────────────────────────
local extractionDone=false

local function doExtractRoots(roots, source)
    if #roots==0 then
        notify("BKS GE","⚠ No hay ScreenGui _zk* en PlayerGui/CoreGui.",8)
        return
    end
    notify("BKS GE",_fmt("%d ScreenGui encontradas. Serializando... (%s)",#roots,source),5)
    local code=buildCode(roots)
    saveAndReport(code)
    extractionDone=true
end

-- ─────────────────────────────────────────────────────────────────────────────
-- EXTRACCIÓN AUTOMÁTICA: busca _zk768057 exacto, espera estabilización
-- ─────────────────────────────────────────────────────────────────────────────
local function autoExtract()
    -- 1. Esperar a que aparezca la GUI principal exacta
    local t0=tick()
    local mainGui=nil

    notify("BKS GE","Esperando _zk768057...",6)

    while (tick()-t0) < CFG.DETECT_TIMEOUT do
        mainGui = findExact(CFG.SGUI_MAIN)
        if mainGui then break end
        task.wait(0.5)
    end

    if not mainGui then
        notify("BKS GE",
            _fmt("Timeout (%ds). _zk768057 no apareció.\nPresiona F8 para capturar lo que haya.",
                CFG.DETECT_TIMEOUT), 12)
        return
    end

    notify("BKS GE","_zk768057 detectada. Esperando que buildGUI() termine...",5)

    -- 2. Esperar estabilización (buildGUI puede tardar ~10s)
    waitStable(mainGui)

    -- 3. Recolectar: main + extras
    local roots={}
    _ins(roots, mainGui)
    for _,nm in _ipairs(CFG.SGUI_EXTRAS) do
        local inst=findExact(nm)
        if inst then _ins(roots,inst) end
    end

    doExtractRoots(roots,"auto-detect")
end

-- ─────────────────────────────────────────────────────────────────────────────
-- KEYBIND F8: captura inmediata de todas las _zk* ScreenGui
-- ─────────────────────────────────────────────────────────────────────────────
UIS.InputBegan:Connect(function(inp,gpe)
    if gpe then return end
    if inp.UserInputType==Enum.UserInputType.Keyboard and inp.KeyCode==CFG.MANUAL_KEY then
        task.spawn(function()
            notify("BKS GE","F8 → capturando AHORA todas las _zk* ScreenGui...",4)
            local roots=findAllZk()
            if #roots==0 then
                notify("BKS GE","No hay ScreenGui _zk* en este momento. Espera a que el hub cargue.",7)
                return
            end
            -- Informar qué se capturará
            local names={}
            for _,r in _ipairs(roots) do _ins(names,safeName(r)) end
            print("[BKS GE] F8 → capturando: ".._cat(names,", "))
            doExtractRoots(roots,"F8 manual")
        end)
    end
end)

