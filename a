-- typeof() puede no estar disponible como global en algunos executors
-- (aunque es nativo de Luau/Roblox, algunos sandboxes lo ocultan)
local _typeof
do
    local ok, tf = _pcall(function() return typeof end)
    if ok and _type(tf) == "function" then
        _typeof = tf
    else
        -- Fallback: usar ClassName para userdata de Roblox
        _typeof = function(v)
            local t = _type(v)
            if t ~= "userdata" then return t end
            -- Intentar leer ClassName (funciona para Instances y DataTypes)
            local ok2, cn = _pcall(function() return v.ClassName end)
            if ok2 and cn then
                -- Distinguir tipos de datos Roblox por sus propiedades únicas
                if _pcall(function() local _ = v.R + v.G + v.B end) then return "Color3" end
                if _pcall(function() local _ = v.X.Scale + v.Y.Scale end) then return "UDim2" end
                if _pcall(function() local _ = v.Scale + v.Offset end) then return "UDim" end
                if _pcall(function() local _ = v.Keypoints[1].Time end) then
                    if _pcall(function() local _ = v.Keypoints[1].Value.R end) then
                        return "ColorSequence"
                    end
                    return "NumberSequence"
                end
                if _pcall(function() local _ = v.EnumType end) then return "EnumItem" end
                -- Si tiene ClassName, es una Instance
                return cn  -- devuelve ClassName como tipo
            end
            -- Vector2: X e Y pero sin Scale/Offset
            if _pcall(function() local _ = v.X + v.Y end) then return "Vector2" end
            return "userdata"
        end
    end
end

-- ─────────────────────────────────────────────────────────────────────────────
-- UTILIDAD: leer propiedad de forma segura
-- ─────────────────────────────────────────────────────────────────────────────
local function safeProp(inst, prop)
    local ok, val = _pcall(function() return inst[prop] end)
    return ok, val
end

local function safeClassName(inst)
    local ok, cn = _pcall(function() return inst.ClassName end)
    return ok and cn or ""
end

local function safeName(inst)
    local ok, n = _pcall(function() return inst.Name end)
    return ok and n or ""
end

-- ─────────────────────────────────────────────────────────────────────────────
-- SERIALIZADORES
-- ─────────────────────────────────────────────────────────────────────────────

local function rnd(n, d)
    local f = 10 ^ (d or 4)
    return _floor(n * f + 0.5) / f
end

local function serNum(n)
    if n == _floor(n) and _abs(n) < 1e7 then
        return _tostr(_floor(n))
    end
    local s = _fmt("%.6f", n)
    s = s:gsub("%.?0+$", "")
    return s == "" and "0" or s
end

local function serStr(s)
    return '"' .. _tostr(s)
        :gsub("\\","\\\\")
        :gsub('"','\\"')
        :gsub("\n","\\n")
        :gsub("\r","\\r")
        :gsub("\t","\\t") .. '"'
end

local function serC3(c)
    local r = _floor(c.R * 255 + .5)
    local g = _floor(c.G * 255 + .5)
    local b = _floor(c.B * 255 + .5)
    return _fmt("Color3.fromRGB(%d, %d, %d)", r, g, b)
end

local function serUDim2(u)
    return _fmt("UDim2.new(%s, %d, %s, %d)",
        _tostr(rnd(u.X.Scale,5)), _floor(u.X.Offset+.5),
        _tostr(rnd(u.Y.Scale,5)), _floor(u.Y.Offset+.5))
end

local function serUDim(u)
    return _fmt("UDim.new(%s, %d)", _tostr(rnd(u.Scale,5)), _floor(u.Offset+.5))
end

local function serV2(v)
    return _fmt("Vector2.new(%s, %s)", serNum(v.X), serNum(v.Y))
end

local function serColorSeq(cs)
    local parts = {}
    for _, kp in _ipairs(cs.Keypoints) do
        _ins(parts, _fmt("    ColorSequenceKeypoint.new(%s, %s)",
            serNum(kp.Time), serC3(kp.Value)))
    end
    return "ColorSequence.new({\n" .. _cat(parts, ",\n") .. "\n})"
end

local function serNumSeq(ns)
    local parts = {}
    for _, kp in _ipairs(ns.Keypoints) do
        _ins(parts, _fmt("    NumberSequenceKeypoint.new(%s, %s, %s)",
            serNum(kp.Time), serNum(kp.Value), serNum(kp.Envelope)))
    end
    return "NumberSequence.new({\n" .. _cat(parts, ",\n") .. "\n})"
end

local function serRect(r)
    return _fmt("Rect.new(%s, %s, %s, %s)",
        serNum(r.Min.X), serNum(r.Min.Y),
        serNum(r.Max.X), serNum(r.Max.Y))
end

-- Serializa cualquier valor Roblox → Lua string
local function serVal(val)
    local t = _typeof(val)
    if t == "nil"             then return "nil"
    elseif t == "boolean"     then return _tostr(val)
    elseif t == "number"      then return serNum(val)
    elseif t == "string"      then return serStr(val)
    elseif t == "Color3"      then return serC3(val)
    elseif t == "UDim2"       then return serUDim2(val)
    elseif t == "UDim"        then return serUDim(val)
    elseif t == "Vector2"     then return serV2(val)
    elseif t == "ColorSequence"  then return serColorSeq(val)
    elseif t == "NumberSequence" then return serNumSeq(val)
    elseif t == "Rect"           then return serRect(val)
    elseif t == "EnumItem"    then
        local ok, s = _pcall(_tostr, val)
        return ok and s or "nil"
    elseif t == "BrickColor"  then
        local ok, s = _pcall(_tostr, val)
        return ok and _fmt('BrickColor.new("%s")', s) or "nil"
    else
        -- Para tipos desconocidos, intentar tostring
        local ok, s = _pcall(_tostr, val)
        if ok and s and s ~= "" and s ~= "nil" then return serStr(s) end
        return "nil"
    end
end

