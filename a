-- ─────────────────────────────────────────────────────────────────────────────
-- SERIALIZADORES DE TIPOS ROBLOX
-- ─────────────────────────────────────────────────────────────────────────────

local function rnd(n, decimals)
    local f = 10 ^ (decimals or 4)
    return _floor(n * f + 0.5) / f
end

local function serNum(n)
    if n == _floor(n) and _abs(n) < 1e7 then
        return _tostr(_floor(n))
    end
    local s = _fmt("%.6f", n):gsub("%.?0+$", "")
    return s
end

local function serColor3(c)
    local r = _floor(c.R * 255 + 0.5)
    local g = _floor(c.G * 255 + 0.5)
    local b = _floor(c.B * 255 + 0.5)
    return _fmt("Color3.fromRGB(%d, %d, %d)", r, g, b)
end

local function serUDim2(u)
    local xs = rnd(u.X.Scale, 5)
    local xo = _floor(u.X.Offset + 0.5)
    local ys = rnd(u.Y.Scale, 5)
    local yo = _floor(u.Y.Offset + 0.5)
    return _fmt("UDim2.new(%s, %d, %s, %d)", _tostr(xs), xo, _tostr(ys), yo)
end

local function serUDim(u)
    local s = rnd(u.Scale, 5)
    local o = _floor(u.Offset + 0.5)
    return _fmt("UDim.new(%s, %d)", _tostr(s), o)
end

local function serVector2(v)
    return _fmt("Vector2.new(%s, %s)", serNum(v.X), serNum(v.Y))
end

local function serEnum(e)
    -- En Roblox, tostring(Enum.Font.Gotham) → "Enum.Font.Gotham"
    local ok, s = _pcall(_tostr, e)
    return ok and s or "nil"
end

local function serString(s)
    -- Escapar comillas dobles, backslashes y saltos de línea
    local esc = s:gsub("\\", "\\\\")
                 :gsub('"',  '\\"')
                 :gsub("\n", "\\n")
                 :gsub("\r", "\\r")
                 :gsub("\t", "\\t")
    return '"' .. esc .. '"'
end

local function serColorSequence(cs)
    local parts = {}
    for _, kp in ipairs(cs.Keypoints) do
        _ins(parts, _fmt("    ColorSequenceKeypoint.new(%s, %s)",
            serNum(kp.Time), serColor3(kp.Value)))
    end
    return "ColorSequence.new({\n" .. _cat(parts, ",\n") .. "\n})"
end

local function serNumberSequence(ns)
    local parts = {}
    for _, kp in ipairs(ns.Keypoints) do
        _ins(parts, _fmt("    NumberSequenceKeypoint.new(%s, %s, %s)",
            serNum(kp.Time), serNum(kp.Value), serNum(kp.Envelope)))
    end
    return "NumberSequence.new({\n" .. _cat(parts, ",\n") .. "\n})"
end

local function serRect(r)
    return _fmt("Rect.new(%s, %s, %s, %s)",
        serNum(r.Min.X), serNum(r.Min.Y),
        serNum(r.Max.X), serNum(r.Max.Y))
end

-- Serializa cualquier valor Roblox → código Lua string
local function serValue(val)
    local t = _typeof(val)
    if t == "nil"             then return "nil"
    elseif t == "boolean"     then return _tostr(val)
    elseif t == "number"      then return serNum(val)
    elseif t == "string"      then return serString(val)
    elseif t == "Color3"      then return serColor3(val)
    elseif t == "UDim2"       then return serUDim2(val)
    elseif t == "UDim"        then return serUDim(val)
    elseif t == "Vector2"     then return serVector2(val)
    elseif t == "ColorSequence"   then return serColorSequence(val)
    elseif t == "NumberSequence"  then return serNumberSequence(val)
    elseif t == "Rect"            then return serRect(val)
    elseif t == "EnumItem"        then return serEnum(val)
    elseif t == "BrickColor"      then
        return _fmt('BrickColor.new("%s")', _tostr(val))
    elseif t == "Font" then
        -- Roblox Font object (nuevo sistema de fuentes)
        local ok, s = _pcall(function()
            return _fmt('Font.fromEnum(Enum.Font.%s)', _tostr(val.Family))
        end)
        return ok and s or serString(_tostr(val))
    else
        -- Último recurso: tostring (funciona para Instances → evitar referencias)
        local ok, s = _pcall(_tostr, val)
        if ok and s and s ~= "" then return serString(s) end
        return "nil"
    end
end

