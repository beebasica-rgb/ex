local function buildCode(roots)
    local lines = {}
    _ins(lines, "--[[")
    _ins(lines, "  BKS HUB — GUI Original (BKS_GUI_EXTRACTOR_v2)")
    _ins(lines, "  Generado: " .. _tostr(tick()))
    _ins(lines, "  Instancias reales extraídas de PlayerGui/CoreGui en runtime.")
    _ins(lines, "--]]")
    _ins(lines, "")
    _ins(lines, 'local Players = game:GetService("Players")')
    _ins(lines, 'local UIS     = game:GetService("UserInputService")')
    _ins(lines, 'local LP      = Players.LocalPlayer')
    _ins(lines, 'local PG      = LP:WaitForChild("PlayerGui")')
    _ins(lines, "")
    -- Limpiar GUIs anteriores
    _ins(lines, "-- Limpiar instancias anteriores del hub")
    _ins(lines, 'for _, nm in ipairs({"' .. _cat(CFG.SGUI_NAMES, '","') .. '"}) do')
    _ins(lines, '    local old = PG:FindFirstChild(nm)')
    _ins(lines, '    if old then old:Destroy() end')
    _ins(lines, 'end')
    _ins(lines, "")
    _ins(lines, "-- ══════════════════════════════════════════")
    _ins(lines, "-- GUI ORIGINAL")
    _ins(lines, "-- ══════════════════════════════════════════")
    _ins(lines, "")

    local counters = {}
    local firstVar = nil
    for _, root in _ipairs(roots) do
        local rlines, rvar = serInst(root, "PG", 0, {}, counters)
        if rvar and not firstVar then firstVar = rvar end
        for _, l in _ipairs(rlines) do _ins(lines, l) end
    end

    -- Keybind
    _ins(lines, "")
    _ins(lines, "-- ══════════════════════════════════════════")
    _ins(lines, "-- KEYBIND TOGGLE (U = mostrar/ocultar)")
    _ins(lines, "-- ══════════════════════════════════════════")
    if firstVar then
        _ins(lines, "local _sg = " .. firstVar)
        _ins(lines, "UIS.InputBegan:Connect(function(inp, gpe)")
        _ins(lines, "    if gpe then return end")
        _ins(lines, "    if inp.KeyCode == Enum.KeyCode.U then")
        _ins(lines, "        _sg.Enabled = not _sg.Enabled")
        _ins(lines, "    end")
        _ins(lines, "end)")
    end
    _ins(lines, "")
    _ins(lines, 'print("[BKS GUI v2] Cargada.")')
    return _cat(lines, "\n")
end

