local function clipSave(text)
    if not CFG.SAVE_CLIPBOARD then return false end
    local ok = _pcall(setclipboard, text)
    if ok then return true end
    ok = _pcall(function() Clipboard:SetText(text) end)
    return ok
end

local function hasteSave(text)
    if not CFG.SAVE_HASTEBIN then return nil end
    local ok, res = _pcall(function()
        return request({
            Url    = "https://hastebin.com/documents",
            Method = "POST", Body = text,
            Headers = {["Content-Type"]="text/plain"},
        })
    end)
    if ok and res and res.Body then
        local ok2, data = _pcall(function() return HttpSvc:JSONDecode(res.Body) end)
        if ok2 and data and data.key then
            return "https://hastebin.com/" .. data.key
        end
    end
    return nil
end

local function rentrySave(text)
    if not CFG.SAVE_HASTEBIN then return nil end
    local ok, res = _pcall(function()
        return request({
            Url    = "https://rentry.co/api",
            Method = "POST",
            Body   = "text=" .. HttpSvc:UrlEncode(text),
            Headers = {
                ["Content-Type"] = "application/x-www-form-urlencoded",
                ["Referer"]      = "https://rentry.co",
            },
        })
    end)
    if ok and res and res.Body then
        local ok2, data = _pcall(function() return HttpSvc:JSONDecode(res.Body) end)
        if ok2 and data and data.url then return data.url .. "/raw" end
    end
    return nil
end

local function chunkPrint(text)
    if not CFG.PRINT_CHUNKS then return end
    local CHUNK = 3500
    local total = #text
    local n     = math.ceil(total / CHUNK)
    print(_fmt("[BKS GE] Imprimiendo %d chunks...", n))
    for i = 1, total, CHUNK do
        print(text:sub(i, i+CHUNK-1))
        task.wait(0.05)
    end
    print("[BKS GE] ── FIN ──")
end

