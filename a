local function notify(title, msg, dur)
    _pcall(function()
        StarterGuiSvc:SetCore("SendNotification", {
            Title=title, Text=msg, Duration=dur or 5,
        })
    end)
    print("[BKS GE] " .. title .. " — " .. msg)
end

