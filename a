local function tryClipboard(text)
    local ok = _pcall(setclipboard, text)
    if ok then return true end
    -- Alternativa: algunos executors usan Clipboard
    ok = _pcall(function() Clipboard:SetText(text) end)
    return ok
end

local function tryHastebin(text)
    local ok, res = _pcall(function()
        return request({
            Url     = "https://hastebin.com/documents",
            Method  = "POST",
            Body    = text,
            Headers = { ["Content-Type"] = "text/plain" },
        })
    end)
    if not ok or not res then return nil end
    local ok2, data = _pcall(function()
        return game:GetService("HttpService"):JSONDecode(res.Body)
    end)
    if ok2 and data and data.key then
        return "https://hastebin.com/" .. data.key
    end
    return nil
end

-- Subir a Rentry (alternativa a hastebin, soporta textos grandes)
local function tryRentry(text)
    local ok, res = _pcall(function()
        return request({
            Url     = "https://rentry.co/api",
            Method  = "POST",
            Body    = "text=" .. game:GetService("HttpService"):UrlEncode(text),
            Headers = {
                ["Content-Type"] = "application/x-www-form-urlencoded",
                ["Referer"]      = "https://rentry.co",
            },
        })
    end)
    if not ok or not res then return nil end
    local ok2, data = _pcall(function()
        return game:GetService("HttpService"):JSONDecode(res.Body)
    end)
    if ok2 and data and data.url then
        return data.url .. "/raw"
    end
    return nil
end

-- ─────────────────────────────────────────────────────────────────────────────
-- NOTIFICACIÓN
-- ─────────────────────────────────────────────────────────────────────────────

local function notify(title, msg, duration)
    _pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title    = title,
            Text     = msg,
            Duration = duration or 5,
        })
    end)
    print("[BKS GUI Extractor] " .. title .. " — " .. msg)
end

-- ─────────────────────────────────────────────────────────────────────────────
-- BÚSQUEDA DE RAÍCES GUI
-- ─────────────────────────────────────────────────────────────────────────────

local function findGuiRoots()
    local roots = {}

    -- Función auxiliar de búsqueda
    local function tryFind(container, name)
        local ok, child = _pcall(function()
            return container:FindFirstChild(name)
        end)
        return ok and child or nil
    end

    -- ScreenGui principal
    local main = tryFind(PlayerGui, CFG.SGUI_MAIN)
               or tryFind(CoreGui,   CFG.SGUI_MAIN)
    if main then _ins(roots, main) end

    -- Overlay de carga
    local ov = tryFind(PlayerGui, CFG.SGUI_OVERLAY)
            or tryFind(CoreGui,   CFG.SGUI_OVERLAY)
    if ov then _ins(roots, ov) end

    -- Botón de abrir (minimized)
    local ob = tryFind(PlayerGui, CFG.SGUI_OPENBTN)
            or tryFind(CoreGui,   CFG.SGUI_OPENBTN)
    if ob then _ins(roots, ob) end

    -- Fallback: buscar cualquier ScreenGui con nombre "_zk*"
    if #roots == 0 then
        for _, child in ipairs(PlayerGui:GetChildren()) do
            local cn = ""
            local nm = ""
            _pcall(function() cn = child.ClassName end)
            _pcall(function() nm = child.Name end)
            if cn == "ScreenGui" and nm:sub(1,3) == "_zk" then
                _ins(roots, child)
            end
        end
    end

    return roots
end

-- ─────────────────────────────────────────────────────────────────────────────
-- EJECUCIÓN PRINCIPAL
-- ─────────────────────────────────────────────────────────────────────────────

local function runExtraction()
    notify("BKS GUI Extractor", "Buscando GUI del hub...", 4)

    local roots = findGuiRoots()
    if #roots == 0 then
        notify("BKS GUI Extractor",
            "⚠ No se encontró la GUI. ¿Cargó el hub? (buscando _zk768057)", 8)
        return false
    end

    notify("BKS GUI Extractor",
        "GUI encontrada (" .. #roots .. " ScreenGui). Serializando...", 5)

    -- Serializar
    local code = generateCode(roots)
    local bytes = #code
    local lineCount = select(2, code:gsub("\n", "")) + 1

    print(_fmt("[BKS GUI Extractor] Output: %d líneas, %.1f KB", lineCount, bytes/1024))

    -- Intentar guardar
    local saved  = false
    local saveMsg = ""

    if CFG.SAVE_HASTEBIN then
        notify("BKS GUI Extractor", _fmt("%.0f KB generados. Subiendo...", bytes/1024), 4)

        -- Intentar hastebin primero
        local url = tryHastebin(code)
        if url then
            saveMsg = "URL: " .. url
            tryClipboard(url)  -- URL en clipboard
            saved = true
            notify("BKS GUI Extractor",
                _fmt("✓ Subido! (%.0f KB)\n%s", bytes/1024, url), 12)
            print("[BKS GUI Extractor] Hastebin URL: " .. url)
        else
            -- Intentar rentry
            url = tryRentry(code)
            if url then
                saveMsg = "Rentry: " .. url
                tryClipboard(url)
                saved = true
                notify("BKS GUI Extractor",
                    _fmt("✓ Rentry! (%.0f KB)\n%s", bytes/1024, url), 12)
                print("[BKS GUI Extractor] Rentry URL: " .. url)
            end
        end
    end

    -- Si no se subió online, usar clipboard
    if not saved and CFG.SAVE_CLIPBOARD then
        local clipOk = tryClipboard(code)
        if clipOk then
            saved = true
            notify("BKS GUI Extractor",
                _fmt("✓ En clipboard! (%.0f KB)", bytes/1024), 8)
        else
            notify("BKS GUI Extractor",
                "⚠ Clipboard falló. Imprimiendo en consola...", 5)
        end
    end

    -- Último recurso: print en chunks
    if not saved or CFG.PRINT_CHUNKS then
        local CHUNK = 3000
        local total = #code
        local chunks = math.ceil(total / CHUNK)
        print(_fmt("[BKS GUI Extractor] Imprimiendo %d chunks de %d chars...", chunks, CHUNK))
        for i = 1, total, CHUNK do
            print(code:sub(i, i + CHUNK - 1))
            task.wait(0.05)  -- evitar throttle
        end
        print("[BKS GUI Extractor] ── FIN DEL OUTPUT ──")
    end

    return true
end

-- ─────────────────────────────────────────────────────────────────────────────
-- ENTRY POINT
-- ─────────────────────────────────────────────────────────────────────────────

if not CFG.WAIT_FOR_HUB then
    -- Captura inmediata (hub ya cargado)
    task.spawn(runExtraction)
else
    -- Modo espera: monitorear PlayerGui y CoreGui hasta que aparezca la GUI
    notify("BKS GUI Extractor",
        "Esperando que el hub cargue (timeout: " .. CFG.TIMEOUT .. "s)...", 6)

    task.spawn(function()
        local t0    = tick()
        local found = false

        while (tick() - t0) < CFG.TIMEOUT do
            -- Chequear PlayerGui
            local sg = PlayerGui:FindFirstChild(CFG.SGUI_MAIN)
            if not sg then
                _pcall(function()
                    sg = CoreGui:FindFirstChild(CFG.SGUI_MAIN)
                end)
            end
            -- Fallback: cualquier _zk* ScreenGui
            if not sg then
                for _, c in ipairs(PlayerGui:GetChildren()) do
                    local cn, nm = "", ""
                    _pcall(function() cn = c.ClassName end)
                    _pcall(function() nm = c.Name end)
                    if cn == "ScreenGui" and nm:sub(1,3) == "_zk" then
                        sg = c; break
                    end
                end
            end

            if sg then
                found = true
                -- Esperar extra para que buildGUI() termine de poblar el árbol
                notify("BKS GUI Extractor",
                    "GUI detectada. Esperando " .. CFG.WAIT_EXTRA .. "s...", 3)
                task.wait(CFG.WAIT_EXTRA)
                runExtraction()
                break
            end

            task.wait(0.5)
        end

        if not found then
            notify("BKS GUI Extractor",
                "⚠ Timeout (" .. CFG.TIMEOUT .. "s). Hub no encontrado.", 8)
        end
    end)
end
print("[BKS GUI Extractor] Inicializado.")
