-- ── 1. Diagnóstico correcto (sin bug de doble type()) ────────────────────────
local diag = {}
local function rawChk(name, fn)
    local ok, raw = pcall(fn)
    if not ok then
        diag[#diag+1] = name .. " = ERROR: " .. tostring(raw):sub(1,80)
    else
        -- mostrar valor real, no type(type(...))
        if type(raw) == "function" then
            diag[#diag+1] = name .. " = function ✓"
        elseif raw == nil then
            diag[#diag+1] = name .. " = NIL ✗✗✗"
        else
            diag[#diag+1] = name .. " = " .. type(raw) .. "(" .. tostring(raw):sub(1,40) .. ")"
        end
    end
end

rawChk("getfenv",        function() return getfenv         end)
rawChk("setfenv",        function() return setfenv         end)
rawChk("getgenv",        function() return getgenv         end)
rawChk("newcclosure",    function() return newcclosure      end)
