-- BÚSQUEDA DE GUIs DEL HUB
-- ─────────────────────────────────────────────────────────────────────────────

local function findRoots()
    local roots  = {}
    local seen   = {}

    local function tryAdd(container, nm)
        if seen[nm] then return end
        local ok, inst = _pcall(function() return container:FindFirstChild(nm) end)
        if ok and inst then seen[nm]=true; _ins(roots, inst) end
    end

    -- Nombres conocidos
    for _, nm in _ipairs(CFG.SGUI_NAMES) do
        tryAdd(PlayerGui, nm)
        tryAdd(CoreGuiSvc, nm)
    end

    -- Fallback: cualquier ScreenGui con prefijo _zk en PlayerGui
    if #roots == 0 then
        local ok, children = _pcall(function() return PlayerGui:GetChildren() end)
        if ok then
            for _, c in _ipairs(children) do
                local cn = safeClassName(c)
                local nm = safeName(c)
                if cn == "ScreenGui" and nm:sub(1,3) == "_zk" and not seen[nm] then
                    seen[nm] = true
                    _ins(roots, c)
                end
            end
        end
    end

    -- Fallback CoreGui
    if #roots == 0 then
        local ok, children = _pcall(function() return CoreGuiSvc:GetChildren() end)
        if ok then
            for _, c in _ipairs(children) do
                local cn = safeClassName(c)
                local nm = safeName(c)
                if cn == "ScreenGui" and nm:sub(1,3) == "_zk" and not seen[nm] then
                    seen[nm] = true
                    _ins(roots, c)
                end
            end
        end
    end

    return roots
end

